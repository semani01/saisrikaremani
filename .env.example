# Portfolio Grand Prix — Environment Variables
# Copy this file to .env.local and fill in your real keys.
# .env.local is gitignored — NEVER commit real keys.

# Claude API (Anthropic) — used by /api/chat for the race engineer chatbot
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ElevenLabs TTS — used by /api/tts for race engineer voice
# Free tier: 10k characters/month
# Get your key at: https://elevenlabs.io/
ELEVENLABS_API_KEY=

# GitHub Personal Access Token (optional) — increases API rate limit from 60 to 5000 req/hr
# Only needed if GitHub stats on the telemetry HUD are rate-limited
# Create at: https://github.com/settings/tokens (read:user scope only)
GITHUB_TOKEN=

# Your LeetCode username — used by /api/leetcode for the timing tower trackside element
LEETCODE_USERNAME=
